# ── Required ─────────────────────────────────────────────────────────────────

# Anthropic API key — get yours at console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...


# ── Optional: Stripe billing ──────────────────────────────────────────────────

# Set to "true" to enable live Stripe billing (default: false / mock mode)
STRIPE_ENABLED=false

# Restricted key for billing only — never use the full secret key here
STRIPE_RESTRICTED_KEY_TWOFLOWER=rk_live_...

# Alias also accepted
# STRIPE_SECRET_KEY=sk_live_...


# ── Optional: Database ────────────────────────────────────────────────────────

# SQLite (default, great for dev/MVP)
# DATABASE_URL=sqlite:///./enrichapi.db

# PostgreSQL (for production)
# DATABASE_URL=postgresql://user:password@localhost:5432/enrichapi


# ── Optional: Cache ───────────────────────────────────────────────────────────

# Redis URL (falls back to fakeredis in-memory if unreachable)
REDIS_URL=redis://localhost:6379


# ── Optional: Rate limiting ───────────────────────────────────────────────────

# Max API calls per key per day (default: 100)
RATE_LIMIT_PER_DAY=100
